# KiboTalk 后端代理环境变量
# 复制本文件为 .env（仓库根目录），填入真实 key。.env 已被 gitignore。
# 仅 apps/api 读取这些变量；key 不会离开后端进程，浏览器拿不到。
#
# 启动顺序：
#   1) pnpm dev:api          # 读 .env，监听 http://localhost:8787
#   2) pnpm dev:playground    # Vite 把 /stt /llm 代理到 8787

# ── 代理端口 ─────────────────────────────────────────────
PORT=8787

# ── 语音转写 (STT) ────────────────────────────────────────
# 两个 provider：
#   - openrouter：云端，走 apps/api 代理（key 藏在后端）
#   - openai   ：标准 OpenAI 兼容 multipart /v1/audio/transcriptions
#                用于本地低延迟，默认指向 mlx-qwen3-asr serve（见 docs/adr/0002）
# STT_<PROVIDER>_MODEL 不填时回退到注册默认值。
STT_ACTIVE=openrouter
STT_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
STT_OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxx
STT_OPENROUTER_MODEL=openai/gpt-4o-transcribe

# 本地 Qwen3-ASR（Apple Silicon，mlx-qwen3-asr serve 默认监听 8765）：
#   pip install "mlx-qwen3-asr[serve]"
#   mlx-qwen3-asr serve --api-key $(openssl rand -hex 16)
# 仍经 apps/api /stt 代理转发；浏览器发 /stt?provider=openai，key 留在服务端。
# 需 apps/api 与 mlx-qwen3-asr 同机（本地 dev）。切到本地：STT_ACTIVE=openai，或浏览器加 ?provider=openai。
# STT_ACTIVE=openai
# STT_OPENAI_BASE_URL=http://localhost:8765/v1
# STT_OPENAI_API_KEY=本地 serve 启动时生成的 key
# STT_OPENAI_MODEL=Qwen3-ASR-1.7B

# ── 大语言模型 (LLM) ─────────────────────────────────────
# 走 xsai（OpenAI 兼容）。provider 与 STT 可不同。
# 已注册：openrouter、openai（本地 LM Studio 等 OpenAI 兼容端点）。
# 模型示例：deepseek-v4-flash、deepseek/deepseek-chat 等。
LLM_ACTIVE=openrouter
LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxx
LLM_OPENROUTER_MODEL=deepseek/deepseek-chat

# 直连 DeepSeek API（OpenAI 兼容）：
# LLM_ACTIVE=openai
# LLM_OPENAI_BASE_URL=https://api.deepseek.com
# LLM_OPENAI_API_KEY=sk-xxxxxxxx
# LLM_OPENAI_MODEL=deepseek-v4-flash

# 本地 LM Studio（Developer → Local Server，默认 :1234，OpenAI-compatible）：
# 需 apps/api 与 LM Studio 同机。鉴权关闭时 API_KEY 填任意非空占位即可。
# LLM_ACTIVE=openai
# LLM_OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# LLM_OPENAI_API_KEY=lm-studio
# LLM_OPENAI_MODEL=google/gemma-4-e4b
